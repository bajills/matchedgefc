# Site
NEXT_PUBLIC_SITE_URL=https://matchedgefc.com

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Email signup (`/api/subscribe`) inserts into `subscribers` — run migration_ux_picks_subscribers.sql
# and add RLS insert policy for `anon` if inserts fail.

# Optional: override stats bar (defaults: 0-0, 0 — launch-honest)
# NEXT_PUBLIC_STAT_WIN_RATE=0-0
# NEXT_PUBLIC_STAT_PICKS=0
# NEXT_PUBLIC_STAT_LEAGUES=10+
# NEXT_PUBLIC_STAT_FREE=Yes

# Stripe (Dashboard → Developers → API keys + Products → Price ID for Edge $15/mo)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_EDGE=
